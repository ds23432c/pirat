# ============================================================
#  ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
#  Этот файл — пример. Реальный .env в публичный репозиторий
#  НЕ коммитим (он уже в .gitignore). Пароли в публичный GitHub
#  выкладывать нельзя.
# ============================================================

# ── Пароль администратора (ОБЯЗАТЕЛЬНО смените!) ──
ADMIN_PASSWORD=piraty2019

# ── Порт (Railway подставляет сам, локально можно задать) ──
PORT=3000

# ============================================================
#  ПОДКЛЮЧЕНИЕ К MYSQL
# ============================================================
#
#  На RAILWAY (рекомендуется): НИЧЕГО сюда не пишем.
#  В сервисе приложения добавляем Variable Reference:
#      MYSQL_URL = ${{ MySQL.MYSQL_URL }}
#  Код сам прочитает её. Пароль остаётся внутри Railway и
#  в репозиторий не попадает.
#
#  ЛОКАЛЬНО: укажите доступ к своей MySQL одним из способов.
#
# Способ А — одной строкой:
# MYSQL_URL=mysql://user:password@host:3306/dbname
#
# Способ Б — по отдельности:
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=piraty
